    "payload": {
      "hypothesis": {
        "title": "基于多模态组学数据的肿瘤异质性预测模型：Vv1.1 修正版（针对数据泄露与内生性偏倚的防御性增强）",
        "details": "本方案旨在构建一个稳健的机器学习Pipeline，用于整合基因组、转录组及临床影像组学数据以预测肿瘤亚型。针对Vv1.0版本中存在的统计学严谨性缺陷，Vv1.1版本进行了核心架构重构。我们引入了严格的嵌套交叉验证策略，将特征选择与超参数调优完全封装在训练折内部，以彻底杜绝'数据穿越'（Data Leakage）风险。同时，针对样本独立性缺失问题，确立了基于患者ID的分层划分协议，确保纵向数据与亲缘关系样本被严格隔离，从而消除内生性偏倚，保证模型评估指标的真实性与泛化能力。",
        "methodology": {
          "technical_safeguards": [
            "实施嵌套交叉验证架构：特征选择（如mRMR, LASSO）及降维操作（PCA）严格限制在内层循环的训练集上进行，严禁在Pipeline初始化阶段对全量数据集进行预筛选，确保测试集在训练阶段绝对不可见。",
            "建立样本去重与分组隔离机制：针对纵向EHR数据或家系GWAS数据，以'Subject_ID'为唯一分组键。采用'GroupKFold'或'Leave-One-Group-Out'策略进行数据划分，确保同一患者的不同时间切片或具有亲缘关系的样本不会同时出现在训练集与验证集中，从而破坏信息泄露路径。"
          ],
          "validation_protocol": "采用5折x5折嵌套交叉验证（5x5-Fold Nested CV）。外层循环用于模型性能评估，内层循环用于特征筛选与超参数网格搜索。最终报告的性能指标为外层测试集上的均值与95%置信区间，并附带Permutation Test（置换检验）结果以排除模型随机拟合的可能性。",
          "bias_control": "针对数据集的类别不平衡问题，在训练折内采用SMOTE-ENN过采样/欠采样混合技术，且采样操作仅应用于内层训练数据。对于批次效应，使用ComBat算法在校正阶段仅利用训练集的统计量（均值/方差）拟合参数，随后转换测试集，防止测试集分布信息回溯至训练过程。"
        },
        "version": "v1.1",
        "patch_log": [
          {
            "attack_type": "数据穿越",
            "patch_applied": "重构Pipeline为严格嵌套结构，将特征选择器封装在CV循环内部，禁止全量预筛选。",
            "supporting_reference": "PMID: 32821695 (Nature Methods; Ambroise et al. discusses the critical necessity of nested CV for feature selection)"
          },
